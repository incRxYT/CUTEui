{
	"geode": "v5.5.3",
	"gd": {
		"win": "2.2081",
		"android": "2.2081"
	},
	"id": "incRX.cuteui",
	"name": "CUTEui",
	"version": "v1.0.0",
	"developer": "incRX",
	"description": "Soft, pastel UI customization — progress bars, trails, panels and more.",
	"tags": ["interface", "cosmetic"],
	"links": {
		"source": "https://github.com/incRxYT/CUTEui"
	},
	"settings": {
		"progress-bar-enabled": {
			"type": "bool",
			"default": true,
			"name": "Custom Progress Bar",
			"description": "Enable CUTEui styled progress bar"
		},
		"progress-bar-color": {
			"type": "color",
			"default": [255, 182, 213],
			"name": "Progress Bar Color",
			"description": "Main fill color of the progress bar"
		},
		"progress-bar-bg-color": {
			"type": "color",
			"default": [240, 220, 255],
			"name": "Progress Bar Background",
			"description": "Background color of the progress bar"
		},
		"progress-bar-rounded": {
			"type": "bool",
			"default": true,
			"name": "Rounded Bar",
			"description": "Use rounded caps on the progress bar"
		},
		"trail-enabled": {
			"type": "bool",
			"default": true,
			"name": "Custom Player Trail",
			"description": "Enable CUTEui styled player trail"
		},
		"trail-color": {
			"type": "color",
			"default": [200, 160, 255],
			"name": "Trail Color",
			"description": "Color of the player trail"
		},
		"trail-opacity": {
			"type": "int",
			"default": 180,
			"min": 0,
			"max": 255,
			"name": "Trail Opacity",
			"description": "Opacity of the player trail (0-255)"
		},
		"trail-length": {
			"type": "int",
			"default": 14,
			"min": 4,
			"max": 30,
			"name": "Trail Length",
			"description": "Length of the player trail"
		},
		"percentage-enabled": {
			"type": "bool",
			"default": true,
			"name": "Custom Percentage Display",
			"description": "Enable CUTEui styled percentage label"
		},
		"percentage-color": {
			"type": "color",
			"default": [255, 160, 200],
			"name": "Percentage Color",
			"description": "Color of the percentage text"
		},
		"percentage-font": {
			"type": "string",
			"default": "bigFont.fnt",
			"name": "Percentage Font",
			"description": "Font used for the percentage label"
		},
		"percentage-font": {
			"type": "string",
			"default": "bigFont.fnt",
			"name": "Percentage Font",
			"description": "Font used for the percentage label"
		}
	}
}
